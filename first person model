--[[
	[Head/Waist Follow Mouse/Camera Script - AUTO EXECUTES ON RESPAWN]
	[Works with both R6 and R15, lets you turn your character's head and waist towards your mouse/camera.]
	[Scripted by (Unknown), upgraded by OhHeyItsCory.]
	[Modified to auto-execute on death/respawn]
	[FIXED: COMPLETELY DISABLED IN FIRST PERSON TO PREVENT SPINNING]
]]

-- Function to initialize head tracking
local function initializeHeadTracking()
	wait()

	--[Pre-Funcs]:
	local Ang = CFrame.Angles
	local aSin = math.asin
	local aTan = math.atan

	--[Constants]:
	local Cam = game.Workspace.CurrentCamera
	local Plr = game.Players.LocalPlayer
	local Mouse = Plr:GetMouse()
	local Body = Plr.Character or Plr.CharacterAdded:wait()
	local Head = Body:WaitForChild("Head")
	local Hum = Body:WaitForChild("Humanoid")
	local Core = Body:WaitForChild("HumanoidRootPart")
	local IsR6 = (Hum.RigType.Value==0)
	local Trso = (IsR6 and Body:WaitForChild("Torso")) or Body:WaitForChild("UpperTorso")
	local Neck = (IsR6 and Trso:WaitForChild("Neck")) or Head:WaitForChild("Neck")
	local Waist = (not IsR6 and Trso:WaitForChild("Waist"))

	--[[Settings]]
	local MseGuide = false
	local TurnCharacterToMouse = false
	local HeadHorFactor = 1
	local HeadVertFactor = 0.6
	local BodyHorFactor = 0.5
	local BodyVertFactor = 0.4
	local UpdateSpeed = 0.5

	local NeckOrgnC0 = Neck.C0
	local WaistOrgnC0 = (not IsR6 and Waist.C0)

	--[Setup]:
	Neck.MaxVelocity = 1/3

	-- Activation]:
	if TurnCharacterToMouse == true then
		MseGuide = true
		HeadHorFactor = 0
		BodyHorFactor = 0
	end

	-- Check if in first person (with rig-specific thresholds)
	local function isInFirstPerson()
		local distFromHRP = (Cam.CFrame.Position - Core.Position).Magnitude
		local distFromHead = (Cam.CFrame.Position - Head.Position).Magnitude
		
		-- Use stricter threshold for R6, original for R15
		if IsR6 then
			return distFromHRP < 1.5 or distFromHead < 1
		else
			return distFromHRP < 2
		end
	end

	-- Connection for rendering
	local renderConnection = game:GetService("RunService").RenderStepped:Connect(function()
		-- COMPLETELY DISABLE HEAD TRACKING IN FIRST PERSON
		if isInFirstPerson() then
			-- Reset to original positions when in first person
			if not IsR6 then
				Neck.C0 = Neck.C0:lerp(NeckOrgnC0, 0.5)
				if Waist then
					Waist.C0 = Waist.C0:lerp(WaistOrgnC0, 0.5)
				end
			else
				Neck.C0 = Neck.C0:lerp(NeckOrgnC0, 0.5)
			end
			return -- Exit early, don't do any head tracking
		end
		
		-- ONLY DO HEAD TRACKING IN THIRD PERSON
		local CamCF = Cam.CoordinateFrame
		if ((IsR6 and Body["Torso"]) or Body["UpperTorso"])~=nil and Body["Head"]~=nil then
			local TrsoLV = Trso.CFrame.lookVector
			local HdPos = Head.CFrame.p
			if IsR6 and Neck or Neck and Waist then
				if Cam.CameraSubject:IsDescendantOf(Body) or Cam.CameraSubject:IsDescendantOf(Plr) then
					local Dist = nil;
					local Diff = nil;
					if not MseGuide then
						Dist = (Head.CFrame.p-CamCF.p).magnitude
						Diff = Head.CFrame.Y-CamCF.Y
						if not IsR6 then
							Neck.C0 = Neck.C0:lerp(NeckOrgnC0*Ang((aSin(Diff/Dist)*HeadVertFactor), -(((HdPos-CamCF.p).Unit):Cross(TrsoLV)).Y*HeadHorFactor, 0), UpdateSpeed/2)
							Waist.C0 = Waist.C0:lerp(WaistOrgnC0*Ang((aSin(Diff/Dist)*BodyVertFactor), -(((HdPos-CamCF.p).Unit):Cross(TrsoLV)).Y*BodyHorFactor, 0), UpdateSpeed/2)
						else
							Neck.C0 = Neck.C0:lerp(NeckOrgnC0*Ang(-(aSin(Diff/Dist)*HeadVertFactor), 0, -(((HdPos-CamCF.p).Unit):Cross(TrsoLV)).Y*HeadHorFactor),UpdateSpeed/2)
						end
					else
						local Point = Mouse.Hit.p
						Dist = (Head.CFrame.p-Point).magnitude
						Diff = Head.CFrame.Y-Point.Y
						if not IsR6 then
							Neck.C0 = Neck.C0:lerp(NeckOrgnC0*Ang(-(aTan(Diff/Dist)*HeadVertFactor), (((HdPos-Point).Unit):Cross(TrsoLV)).Y*HeadHorFactor, 0), UpdateSpeed/2)
							Waist.C0 = Waist.C0:lerp(WaistOrgnC0*Ang(-(aTan(Diff/Dist)*BodyVertFactor), (((HdPos-Point).Unit):Cross(TrsoLV)).Y*BodyHorFactor, 0), UpdateSpeed/2)
						else
							Neck.C0 = Neck.C0:lerp(NeckOrgnC0*Ang((aTan(Diff/Dist)*HeadVertFactor), 0, (((HdPos-Point).Unit):Cross(TrsoLV)).Y*HeadHorFactor), UpdateSpeed/2)
						end
					end
				end
			end
		end
		if TurnCharacterToMouse == true then
			Hum.AutoRotate = false
			Core.CFrame = Core.CFrame:lerp(CFrame.new(Core.Position, Vector3.new(Mouse.Hit.p.x, Core.Position.Y, Mouse.Hit.p.z)), UpdateSpeed / 2)
		else
			Hum.AutoRotate = true
		end
	end)
	
	-- Return connection so we can disconnect it later
	return renderConnection
end

-- Auto-execute head tracking on initial load
local currentHeadTrackingConnection = initializeHeadTracking()

-- Auto-execute head tracking on respawn
game.Players.LocalPlayer.CharacterAdded:Connect(function()
	-- Disconnect old connection if it exists
	if currentHeadTrackingConnection then
		currentHeadTrackingConnection:Disconnect()
	end
	
	-- Wait a bit for character to fully load
	wait(0.5)
	
	-- Reinitialize head tracking
	currentHeadTrackingConnection = initializeHeadTracking()
	
	print("Head tracking reinitialized on respawn!")
end)


