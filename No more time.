local function setFullBright()
    Lighting.Brightness=Cfg.FB_Brightness; Lighting.ClockTime=14
    Lighting.FogEnd=1e8; Lighting.GlobalShadows=false
    Lighting.OutdoorAmbient=Color3.new(1,1,1); Lighting.Ambient=Color3.new(1,1,1)
    Lighting.ExposureCompensation=math.clamp(Cfg.FB_Brightness*0.8,0,3)
end
local function resetLighting()
    local p=SKY_LIGHTING.default
    Lighting.Brightness=p.brightness; Lighting.ClockTime=p.clock
    Lighting.FogEnd=p.fogEnd; Lighting.GlobalShadows=p.shadows
    Lighting.OutdoorAmbient=p.outdoor; Lighting.Ambient=p.ambient
    Lighting.ExposureCompensation=0
end
