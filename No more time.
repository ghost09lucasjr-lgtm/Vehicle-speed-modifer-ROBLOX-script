-- ========== Vehicle Filter (from EvadeESP) ==========
local V_TAGS = {"Vehicle","Car","Prop","Decoration","Map"}
local V_PATS = {"^Vehicle","^Car","^Truck","^Boat","^Plane","^Heli","^Train","^Tank","^Bike","^Bus"}
local V_NAMES = { ["ATV"]=true, ["Altima"]=true, ["Miata"]=true, ["Forklift"]=true, ["Ghost"]=true, ["Rover"]=true, ["Alien"]=true }
local function IsVehicle(m)
    if V_NAMES[m.Name] then return true end
    if m:FindFirstChildOfClass("VehicleSeat") then return true end
    if m:FindFirstChildOfClass("Seat") then return true end
    for _,t in ipairs(V_TAGS) do if CollectionService:HasTag(m,t) then return true end end
    for _,p in ipairs(V_PATS) do if m.Name:match(p) then return true end end
    return false
end
