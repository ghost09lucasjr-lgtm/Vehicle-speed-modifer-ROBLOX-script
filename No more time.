local function RemoveSky()
    for _,obj in ipairs(Lighting:GetChildren()) do if obj:IsA("Sky") or obj:IsA("Atmosphere") then obj:Destroy() end end
end
local function ApplySkyFaces(faces)
    RemoveSky()
    local sky = Instance.new("Sky")
    sky.SkyboxBk = faces.bk or faces.SkyboxBk or pshade_cussky.bk
    sky.SkyboxDn = faces.dn or faces.SkyboxDn or pshade_cussky.dn
    sky.SkyboxFt = faces.ft or faces.SkyboxFt or pshade_cussky.ft
    sky.SkyboxLf = faces.lt or faces.lf or faces.SkyboxLf or pshade_cussky.lf
    sky.SkyboxRt = faces.rt or faces.SkyboxRt or pshade_cussky.rt
    sky.SkyboxUp = faces.up or faces.SkyboxUp or pshade_cussky.up
    sky.StarCount = faces.stars or 0
    sky.Parent = Lighting
end
local function ApplyLightingPreset(preset)
    local p = SKY_LIGHTING[preset] or SKY_LIGHTING.default
    Lighting.ClockTime=p.clock; Lighting.Brightness=p.brightness
    Lighting.GlobalShadows=p.shadows; Lighting.FogEnd=p.fogEnd
    Lighting.Ambient=p.ambient; Lighting.OutdoorAmbient=p.outdoor
end
local function ApplySkybox(name)
    Cfg.CurrentSkybox = name
    if name == "Default (Game)" then
        RemoveSky(); ApplyLightingPreset("default")
        if next(originalSky) then ApplySkyFaces(originalSky) end
    elseif name == "pshade Default" then
        ApplySkyFaces(pshade_cussky); ApplyLightingPreset("pshade")
    elseif name == "Morning" then
        ApplySkyFaces(loadedSkyboxes.morning or pshade_cussky); ApplyLightingPreset("morning")
    elseif name == "Midday" then
        ApplySkyFaces(loadedSkyboxes.midday  or pshade_cussky); ApplyLightingPreset("midday")
    elseif name == "Afternoon" then
        ApplySkyFaces(loadedSkyboxes.afternoon or pshade_cussky); ApplyLightingPreset("afternoon")
    elseif name == "Evening" then
        ApplySkyFaces(loadedSkyboxes.evening or pshade_cussky); ApplyLightingPreset("evening")
    elseif name == "Rain" then
        ApplySkyFaces(loadedSkyboxes.rain or pshade_cussky); ApplyLightingPreset("rain")
        local a=Instance.new("Atmosphere",Lighting); a.Density=0.6; a.Haze=2.5
        a.Color=Color3.fromRGB(100,110,120); a.Decay=Color3.fromRGB(80,90,100)
    elseif name == "Cloudy" then
        ApplySkyFaces(loadedSkyboxes.cloudy or pshade_cussky); ApplyLightingPreset("cloudy")
        local a=Instance.new("Atmosphere",Lighting); a.Density=0.4; a.Haze=1.5
        a.Color=Color3.fromRGB(150,155,160); a.Decay=Color3.fromRGB(130,135,140)
    end
end

